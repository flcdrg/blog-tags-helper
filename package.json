{
  "name": "blog-tags-helper",
  "displayName": "Blog Tags Helper",
  "description": "Provides minor intellisense when using tags in frontmatter",
  "version": "1.2.0",
  "publisher": "kaellarkin",
  "repository": {
    "url": "https://github.com/flcdrg/blog-tags-helper.git",
    "type": "git"
  },
  "engines": {
    "vscode": "^1.41.1"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "Blog",
    "Hugo",
    "markdown",
    "tags",
    "frontmatter"
  ],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "contributes": {
    "commands": [
      {
        "command": "blog-tags-helper.regenerateTags",
        "title": "Regenerate Blog Tags"
      },
      {
        "command": "blog-tags-helper.test",
        "title": "DONOTUSE: Parse blog tags in this document"
      }
    ],
    "configuration": {
      "title": "Blog Tags Helper",
      "properties": {
        "blogTagsHelper.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable the Blog Tags Helper extension"
        },
        "blogTagsHelper.fileGlobPattern": {
          "type": "string",
          "default": "**/index.md",
          "description": "Glob pattern to find markdown files with frontmatter (e.g., 'src/posts/**/*.md', 'content/**/*.md')"
        }
      }
    }
  },
  "icon": "icon.png",
  "main": "./out/extension.js",
  "capabilities": {
    "completionProvider": {
      "resolveProvider": true,
      "triggerCharacters": [
        "\"",
        "'"
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.41.1",
    "@types/mocha": "^10.0.6",
    "@types/node": "18.x",
    "@typescript-eslint/eslint-plugin": "^7.4.0",
    "@typescript-eslint/parser": "^7.4.0",
    "eslint": "^8.57.0",
    "typescript": "^5.3.3",
    "@vscode/test-cli": "^0.0.8",
    "@vscode/test-electron": "^2.3.9"
  }
}